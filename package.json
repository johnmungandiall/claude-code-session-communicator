{
  "name": "@ruflo/mcp-session-communicator",
  "version": "1.0.0",
  "description": "MCP server for cross-session communication and state management in Claude Code",
  "type": "module",
  "main": "index.js",
  "bin": {
    "session-communicator": "./cli.js"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "node integration-test.js",
    "demo": "node demo.js",
    "hooks:install": "node hooks.js install",
    "hooks:uninstall": "node hooks.js uninstall",
    "install": "node install.js",
    "postinstall": "node install.js"
  },
  "keywords": [
    "mcp",
    "session",
    "communication",
    "state-management",
    "claude-code",
    "ruflo",
    "cross-session",
    "messaging",
    "coordination"
  ],
  "author": "RuFlo Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruvnet/ruflo.git",
    "directory": "src/mcp-servers/session-communicator"
  },
  "bugs": {
    "url": "https://github.com/ruvnet/ruflo/issues"
  },
  "homepage": "https://github.com/ruvnet/ruflo#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "index.js",
    "cli.js",
    "bridge.js",
    "hooks.js",
    "install.js",
    "demo.js",
    "package.json",
    "README.md",
    "LICENSE"
  ]
}
